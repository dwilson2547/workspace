{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Task Queue Manager",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "open": true
      },
      "dialog": {
        "open": true,
        "save": true
      },
      "fs": {
        "readDir": true,
        "scope": ["**"]
      }
    },
    "bundle": {
      "active": true,
      "icon": [],
      "identifier": "com.taskqueue.app",
      "targets": "all"
    },
    "security": {
      "csp": null
    },
    "windows": []
  }
}
