{
  "name": "desktop-task-manager",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/electron/main.js",
  "scripts": {
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "dev": "concurrently -k -s first \"rm -rf dist/main/electron && tsc -p electron/tsconfig.json --watch\" \"vite\" \"wait-on tcp:5173 dist/main/electron/main.js dist/main/electron/preload.js && VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build:renderer": "vite build",
    "build:main": "tsc -p electron/tsconfig.json",
    "build": "npm run build:renderer && npm run build:main",
    "lint": "eslint . --ext .ts,.tsx",
    "start": "electron ."
  },
  "dependencies": {
    "better-sqlite3": "^9.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "concurrently": "^8.2.2",
    "electron": "^30.0.2",
    "electron-rebuild": "^3.2.9",
    "eslint": "^8.57.0",
    "typescript": "^5.4.2",
    "vite": "^5.2.0",
    "wait-on": "^7.2.0"
  }
}
