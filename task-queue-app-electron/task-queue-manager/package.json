{
  "name": "task-queue-manager",
  "version": "1.0.0",
  "description": "Desktop application for managing task queues and workflows",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "electron .",
    "electron:dev": "concurrently \"npm run dev:main\" \"wait-on dist/main/index.js && electron .\" \"npm run dev:renderer\"",
    "package": "npm run build && electron-builder",
    "rebuild": "electron-rebuild"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "better-sqlite3": "^11.3.0",
    "tar": "^7.4.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.51.1",
    "@types/archiver": "^6.0.2",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/tar": "^6.1.13",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^31.2.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "lucide-react": "^0.408.0",
    "postcss": "^8.4.39",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.25.1",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "wait-on": "^7.2.0",
    "zustand": "^4.5.4"
  },
  "build": {
    "appId": "com.taskqueue.manager",
    "productName": "Task Queue Manager",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
